<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header with Title and Pin -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/noteTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Note Title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Meeting Notes - Q4 Planning" />

            <ImageView
                android:id="@+id/pinIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/btn_star_big_on"
                app:tint="#F59E0B"
                android:visibility="gone"
                android:contentDescription="@string/pinned_note"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- Note Preview -->
        <TextView
            android:id="@+id/notePreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Note preview text..."
            android:textSize="14sp"
            android:textColor="#64748B"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp"
            tools:text="Discussed quarterly goals and objectives. Key points include increasing user engagement and launching new features." />

        <!-- Tags -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/tagsChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:chipSpacing="6dp"
            app:singleLine="true">

            <!-- Tags will be added dynamically -->

        </com.google.android.material.chip.ChipGroup>

        <!-- Meta Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/noteDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2 hours ago"
                android:textSize="12sp"
                android:textColor="#94A3B8"
                tools:text="2 hours ago" />

            <!-- Icons for attachments, reminders, location -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/attachmentIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_menu_attachment"
                    app:tint="#94A3B8"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Has attachments"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/reminderIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_menu_recent_history"
                    app:tint="#94A3B8"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Has reminder"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/locationIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_menu_mylocation"
                    app:tint="#94A3B8"
                    android:visibility="gone"
                    android:contentDescription="Has location"
                    tools:visibility="visible" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>